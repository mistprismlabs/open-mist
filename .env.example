# ── 飞书应用 ──
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_OWNER_ID=ou_your_owner_open_id

# ── Claude Agent SDK ──
ANTHROPIC_API_KEY=sk-ant-your_key
CLAUDE_MODEL=claude-opus-4-6

# ── 飞书多维表格 ──
BITABLE_APP_TOKEN=your_app_token
CHAT_LOG_APP_TOKEN=your_chat_log_app_token
CHAT_LOG_TABLE_ID=your_chat_log_table_id

# ── 通知 ──
NOTIFY_CHAT_ID=oc_your_chat_id

# ── 部署 ──
TASK_DOMAIN=your-domain.com
TASK_MAX_BUDGET_USD=2.0
SITES_DIR=/path/to/sites
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem

# ── 腾讯云 COS ──
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your-bucket-id
COS_REGION=ap-your-region

# ── 记忆系统 ──
DASHSCOPE_API_KEY=sk-your_dashscope_key
ADMIN_USER_ID=                          # 管理员的飞书 open_id（可选，不填则 fallback 到 FEISHU_OWNER_ID）

# ── Heartbeat ──
PROJECT_DIR=/path/to/project
CLAUDE_BIN=claude
AUX_SERVICE_NAME=
AUX_HEALTHCHECK_URL=

# ── 企业微信（可选）──
WECOM_CORP_ID=your_corp_id
WECOM_APP_AGENT_ID=your_agent_id
WECOM_APP_SECRET=your_secret
WECOM_APP_TOKEN=your_token
WECOM_APP_ENCODING_AES_KEY=your_aes_key
WECOM_BOT_KEY=your_bot_key

# ── 微信龙虾（可选）──
WEIXIN_ENABLED=false
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_ACCOUNT_ID=
WEIXIN_ALLOW_FROM=
WEIXIN_BOT_TYPE=3

# ── 管理工具 ──
APP_USER=openmist
SERVICE_NAME=openmist.service
BOT_NAME=OpenMist
USER_TITLE=
SYNC_REMOTE=
LOCAL_MEMORY_DIR=$HOME/.claude/memory
